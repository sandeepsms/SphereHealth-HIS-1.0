# Copy to Backend/.env and fill in real values. Do not commit Backend/.env.

# MongoDB connection string. Use a dedicated DB user per environment.
MONGO_URI=mongodb://localhost:27017/spherehealth

# JWT signing secret. MUST be at least 32 characters of cryptographic
# randomness (e.g. `openssl rand -base64 48`). Server refuses to start if
# this is missing or too short.
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Access token lifetime. zeit/ms format.
JWT_EXPIRES=8h

# HTTP port for the Express server.
PORT=5000

# Comma-separated list of origins allowed to call this API. The browser
# preflight rejects anything not listed. Add the production frontend URL
# here when deploying.
CORS_ORIGINS=http://localhost:5173
