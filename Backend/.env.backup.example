# ── SphereHealth backup config (R7hr-253) ───────────────────────────
# Copy the lines you want into Backend/.env (which is gitignored).
# Sensible defaults apply if you leave these unset.

# Same Mongo connection the app uses (already in .env as MONGO_URI).
# MONGO_URI=mongodb://localhost:27017/spherehealth

# OFFLINE copy — a local or EXTERNAL-DRIVE folder. Point this at an
# external/USB/NAS drive so a disk failure on the main box can't take the
# backups with it. Default: C:\SphereBackups
BACKUP_OFFLINE_DIR=C:\SphereBackups

# ONLINE copy — a CLOUD-SYNCED folder (OneDrive / Google Drive / Dropbox
# desktop app). The OS sync client uploads it off-site automatically.
# If unset, the script auto-uses %OneDrive%\SphereBackups when OneDrive
# is configured on this PC. Set it explicitly to be sure:
# BACKUP_SYNCED_DIR=C:\Users\Dr Sandeep\OneDrive\SphereBackups

# Retention — how many backups to keep in EACH location before pruning.
BACKUP_NIGHTLY_KEEP=14
BACKUP_MONTHLY_KEEP=24

# Throwaway DB used by the monthly restore-drill (auto-created + dropped).
# BACKUP_VERIFY_URI=mongodb://localhost:27017/spherehealth_verify_drill

# ── R7hr-254 safety knobs (sensible defaults; usually leave unset) ──
# Refuse to archive a backup smaller than this (catches wrong-DB/auth-fail):
# BACKUP_MIN_DOCS=1
# BACKUP_MIN_COLLS=1
# Allow a run with NO off-site copy (NOT recommended for DR):
# BACKUP_ALLOW_OFFLINE_ONLY=1
# Allow a backup that is >50% smaller than the last good one (real bulk delete):
# BACKUP_ALLOW_SHRINK=1
