# ── Per-hospital deployment config ──────────────────────────────────────────
# Copy to deploy/<slug>.env and fill in. provision-hospital.sh generates this
# automatically with strong random secrets — you rarely edit it by hand.
#
# NEVER commit a real .env (deploy/.gitignore keeps *.env out of git).

# Short unique slug — lowercase, no spaces. Used as the compose project name
# AND the MongoDB database name for this hospital.
HOSPITAL_SLUG=apollo

# Public URL where staff reach the app (used for CORS). With a TLS proxy in
# front this is your https:// hostname.
PUBLIC_URL=https://apollo.bims.example.com

# Host port the frontend (nginx) is published on. Each hospital on the same
# server needs a unique port (8080, 8081, …) behind your reverse proxy.
PUBLIC_HTTP_PORT=8080

# Interface the plain-HTTP port binds to. Set 127.0.0.1 when a TLS reverse
# proxy on the SAME host fronts the app (recommended — keeps the unencrypted
# port off the network). Leave 0.0.0.0 only for LAN-internal on-prem installs.
BIND_ADDR=0.0.0.0

# IANA timezone for IST-anchored crons / day-book / GST snapshots.
HOSPITAL_TZ=Asia/Kolkata

# ── Secrets — change these; never reuse across hospitals ────────────────────
# JWT signing secret. MUST be >= 32 chars (backend fails to boot otherwise).
JWT_SECRET=replace-with-a-long-random-string-at-least-32-characters

# MongoDB root credentials for THIS hospital's mongo container.
MONGO_USER=apollo_admin
MONGO_PASSWORD=replace-with-a-strong-random-password
